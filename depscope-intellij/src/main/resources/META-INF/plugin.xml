<idea-plugin>
    <id>com.depscope.plugin</id>
    <name>DepScope</name>
    <vendor email="support@depscope.dev" url="https://github.com/depscope">DepScope</vendor>
    <version>1.0.0</version>

    <description><![CDATA[
        <h2>DepScope — Dependency Risk Analyzer</h2>
        <p>Analyze the health, security, and maintenance risk of your project dependencies
        directly inside IntelliJ IDEA. Supports npm, Flutter/Dart, and Android/Gradle projects.</p>
        <ul>
            <li>🔴 Risk scoring across 5 dimensions (maintenance, security, popularity, community, depth)</li>
            <li>🛡️ Security vulnerability detection (npm CVEs)</li>
            <li>📊 Interactive dashboard with dependency graph</li>
            <li>🤖 AI-powered insights via Groq (llama-3.3-70b-versatile)</li>
            <li>✏️ Editor gutter annotations for risk levels</li>
        </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends optional="true" config-file="withTerminal.xml">org.jetbrains.plugins.terminal</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
            id="DepScope"
            anchor="right"
            icon="/icons/depscope.svg"
            factoryClass="com.depscope.DepScopeToolWindowFactory"
        />
        <applicationConfigurable
            parentId="tools"
            instance="com.depscope.SettingsConfigurable"
            id="com.depscope.settings"
            displayName="DepScope"
        />
        <applicationService serviceImplementation="com.depscope.SettingsState"/>
        <statusBarWidgetFactory
            id="DepScopeStatusBar"
            implementation="com.depscope.StatusBarWidgetFactory"
            order="last"
        />
        <annotator
            language="JSON"
            implementationClass="com.depscope.EditorAnnotator"
        />
        <annotator
            language="yaml"
            implementationClass="com.depscope.EditorAnnotator"
        />
        <notificationGroup
            id="DepScope"
            displayType="BALLOON"
        />
    </extensions>

    <actions>
        <action
            id="depscope.analyze"
            class="com.depscope.actions.AnalyzeAction"
            text="Analyze with DepScope"
            description="Run DepScope dependency risk analysis on this file"
            icon="/icons/depscope.svg"
        >
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>
        <action
            id="depscope.openDashboard"
            class="com.depscope.actions.OpenDashboardAction"
            text="Open DepScope Dashboard"
            description="Open the DepScope risk analysis dashboard"
        >
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
